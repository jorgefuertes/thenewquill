// npc: fires when response or another table calls ENGAGE <char>.
// Header is `<noun|*> <adj|*|_>:` — matches a character by its (noun, adj)
// pair (specs §2.3). In happy, all three characters are declared as
// `<label>: <noun> _` so slot 2 is `_` in the specific handlers.

TABLE npc

    // Hostile branch first: if the dwarf has lost his patience and hasn't
    // attacked yet, he hits the player now. Specific before generic.
    enano _:
        ZERO enano.patience
        NE enano.death true
        SET enano.death true
        DEC player.health 25
        WRITELN dwarf-rage
        DONE

    // Regular interaction: the dwarf grunts and loses some patience.
    enano _:
        NOT HUMAN enano               // defensive: never run on the player
        IN_ROOM enano cuartelillo
        DEC enano.patience 10
        WRITELN dwarf-grunt
        OK

    // The elf, when visible, just cries.
    elfo _:
        EQ elfo.hidden false
        WRITELN elf-cry
        OK

    // The elf, when hidden, returns "you don't see them".
    elfo _:
        EQ elfo.hidden true
        WRITELN elf-hidden
        DONE

    // Catch-all for any other NPC with no adjective.
    * _:
        WRITE cant-do
        DONE

    // Even broader catch-all: any NPC with any adjective.
    * *:
        WRITE cant-do
        DONE

END TABLE
