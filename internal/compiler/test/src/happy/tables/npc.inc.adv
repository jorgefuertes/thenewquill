// npc: fires only when the SL noun resolves to a (non-human) character.
// Header `<verb|*|_> <npc-noun|*|_>:`. Binding `NPC` is live inside.
// Also handles the quoted-speech form (`decir <npc> "<subSL>"`) with
// nested sub-processes (spec §"Hablar con NPCs: comillas y sub-SLs").

TABLE npc

    // ---------------------------------------------------------------------
    // Reachability check.
    // ---------------------------------------------------------------------

    * *:
        NOT ISHERE NPC
        PRINT cant-do
        DONE

    // ---------------------------------------------------------------------
    // Enano — rage trigger when patience runs out.
    // ---------------------------------------------------------------------

    examinar enano:
        ZERO enano.patience
        NOT EQ enano.death true
        SET enano.death true
        DEC player.health 25
        PRINT dwarf-rage
        DONE

    // Talk to the dwarf while in the guards' room: grunts and loses
    // patience.
    decir enano:
        ISAT enano cuartelillo
        DEC enano.patience 10
        PRINT dwarf-grunt
        OK

    // Generic dwarf talk elsewhere.
    decir enano:
        ENGAGE enano
        DONE

    // ---------------------------------------------------------------------
    // Elfo — hidden vs visible.
    // ---------------------------------------------------------------------

    examinar elfo:
        EQ elfo.hidden true
        PRINT elf-hidden
        DONE

    examinar elfo:
        PRINT elf-cry
        DONE

    // Calling the elf brings him to the guards' room.
    decir elfo:
        ENGAGE elfo
        MOVE elfo cuartelillo
        DONE

    // ---------------------------------------------------------------------
    // Talking to the elf between quotes (sub-processes).
    // Players: `decir elfo "dame el talismán y examina la bolsa"`
    // ---------------------------------------------------------------------

    decir elfo:
        // Preludio — runs once when entering the outer.
        SET elfo.hidden false
        PRINT elf-cry

        dar talismán:
            ISCARRIED talismán
            GIVE talismán elfo
            PRINT ok
            OK

        dar *:
            PRINT havent, ITEM
            NOOK

        examinar *:
            PRINT elf-cry
            END

        * *:
            PRINT cant-do
            NOOK

    // ---------------------------------------------------------------------
    // NPC catch-all.
    // ---------------------------------------------------------------------

    * *:
        PRINT cant-do
        DONE

END TABLE
