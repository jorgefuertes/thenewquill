// response: general / fallback table. Runs after turn, item and npc.
// Header `<verb|*|_> <noun|*|_>:`.

TABLE response

    // ---------------------------------------------------------------------
    // Save game — prompt for filename, refuse empty input.
    // ---------------------------------------------------------------------

    save _:
        INPUT name "Nombre de la partida: "
        NOT ISEMPTY name
        SAVE name
        PRINT ok
        OK

    save _:
        PRINT err-save, name
        NOOK

    // ---------------------------------------------------------------------
    // RAM-style load — placeholder for LOAD coverage.
    // ---------------------------------------------------------------------

    ram _:
        INPUT name "Nombre de la partida: "
        NOT ISEMPTY name
        LOAD name
        PRINT ok
        OK

    // ---------------------------------------------------------------------
    // Quit & restart.
    // ---------------------------------------------------------------------

    fin _:
        PRINT sure
        PRINT bye
        QUIT

    quill _:
        // `quill` / `thenewquill` / `tnq` → restart the whole adventure.
        RESTART

    // ---------------------------------------------------------------------
    // Syntax-shape catch-alls.
    // ---------------------------------------------------------------------

    _ *:
        // Noun alone, no verb.
        PRINT cant
        DONE

    * _:
        // Verb alone, no noun.
        PRINT cant
        DONE

    * *:
        // Anything else we didn't understand.
        PRINT cant
        DONE

END TABLE
