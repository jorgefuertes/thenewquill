// cron: clock-driven background processes.
// Header `<HOURS|MINUTES|SECONDS|AT> <n|"HH:MM:SS">` (spec §"Cabeceras en
// la tabla `cron`"). No SL nor bindings inside.

TABLE cron

    // Every 30 wall seconds: 25% chance of distant thunder.
    SECONDS 30:
        CHANCE 25
        PRINT storm
        OK

    // Every minute: hunger creeps up by one.
    MINUTES 1:
        INC hunger 1

    // Hunger 5–9: warn.
    MINUTES 1:
        GTE hunger 5
        LT hunger 10
        PRINT hungry
        DONE

    // Hunger ≥ 10: starving, bleed health.
    MINUTES 1:
        GTE hunger 10
        PRINT starving
        DEC player.health 5
        DONE

    // Once an hour, after a satiated hunger reset, show a score reminder.
    HOURS 1:
        ZERO hunger
        PRINT score-msg, score, turns
        OK

    // Once an hour, generic ping.
    HOURS 1:
        PRINT score-msg, score, turns
        OK

    // Every wall minute, if the score is huge, congratulate.
    MINUTES 1:
        GT score 100
        PRINT ok
        OK

    // At midnight every day, say goodnight.
    AT "00:00:00":
        PRINT bye

    // Every 5 seconds: if the player's health is fatal, teleport to the
    // death location (the `location` table picks it up from there).
    SECONDS 5:
        LTE player.health 0
        GOTO muerte
        DONE

END TABLE
