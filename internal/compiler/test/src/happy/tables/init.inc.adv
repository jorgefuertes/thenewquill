// init: runs once at adventure start (or restart).
// Header `_ _:` (no SL to match).

TABLE init

    _ _:
        // Terminal setup.
        CLEAR
        WINDOW 0
        BG 0
        FG 7
        CURSOR off
        AT 1 1

    _ _:
        // Welcome screen.
        PRINT intro
        WAIT 1500

    _ _:
        // Counters.
        SET turns 0
        SET score 0
        SET hunger 0

    _ _:
        // Randomize dwarf patience so each run differs a bit.
        RANDOM enano.patience 200 255

    _ _:
        // Torch starts unlit, placed far from the player.
        DESTROY ant-on
        CREATE ant-off tumba
        SET ant-on.on false

    _ _:
        // Elf starts hidden in the stands.
        SET elfo.hidden true
        MOVE elfo gradas

    _ _:
        // Placeholder slot — kept to exercise NOOP.
        NOOP

END TABLE
