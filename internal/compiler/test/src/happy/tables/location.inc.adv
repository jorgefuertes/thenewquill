// location: fires on entering or leaving a location.
// Header `<IN|OUT|*> <loc|*>:` (spec §"Cabeceras en la tabla `location`").

TABLE location

    // ---------------------------------------------------------------------
    // First-time entries — show a longer intro and flip a `visited` flag.
    // ---------------------------------------------------------------------

    IN celda:
        EQ celda.visited false
        PRINT intro
        SET celda.visited true
        END

    IN celda:
        // Second and later visits.
        PRINT new-location
        DONE

    IN exterior:
        EQ exterior.visited false
        SET exterior.visited true
        PRINT new-location
        DONE

    // ---------------------------------------------------------------------
    // Death location: announce and end the game.
    // ---------------------------------------------------------------------

    IN muerte:
        PRINT dead
        PRINT end-game
        DONE

    // ---------------------------------------------------------------------
    // Generic catch-alls.
    // ---------------------------------------------------------------------

    IN *:
        // After any entry, show the standard short description.
        NOT EQ celda.visited false
        PRINT new-location
        DONE

    OUT *:
        // Hook for "leaving any room" — falls through (implicit END).

END TABLE
